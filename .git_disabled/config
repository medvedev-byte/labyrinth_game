[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/medvedev-byte/labyrinth_game.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[branch "testing_qwen"]
	remote = origin
	merge = refs/heads/testing_qwen
	vscode-merge-base = origin/testing_qwen
